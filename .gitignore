.DS_Store
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/

# Secrets and credentials
.env
.env.*
!.env.example
*.pem
*.key
.aws/
.ssh/

# Google verification
google*.html

# Generated URL-check / normalize reports
chat-url-safety-report.txt
normalize-report.txt
url-safety-report.txt

# Terraform — commit .tf source and .terraform.lock.hcl; ignore everything else
**/.terraform/
**/.terraform.tfstate.lock.info
*.tfstate
*.tfstate.*
*.tfplan
tfplan
tfplan-*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Claude Code scheduled tasks lockfile (per-machine state)
.claude/scheduled_tasks.lock

# Pagefind search index — generated by gcp-deploy.yml on every deploy.
# Never committed; lives only inside the deployed Docker image.
/_pagefind/
