# Copy to .env and fill in.
# .env is gitignored — never commit real credentials.

# --- Zoom Server-to-Server OAuth (for tools/fetch_zoom_transcript.py) ---
# Create at https://marketplace.zoom.us/develop/create → "Server-to-Server OAuth".
# Required scopes: recording:read, user:read, meeting:read.
# "Account ID" is under App Credentials in the app settings.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
